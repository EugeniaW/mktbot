# Deep Research Bot Environment Configuration

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Tavily API Key (from https://tavily.com)
# Free tier: 1000 queries/month
TAVILY_API_KEY=tvly-your-key-here

# Optional: Webhook URL for production (DigitalOcean)
# Format: https://your-domain.com/webhook
# WEBHOOK_URL=

# Optional: Port for webhook (default: 8443)
# PORT=8443

# Optional: Claude API Key (for future upgrade)
# Get from: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude Model
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
